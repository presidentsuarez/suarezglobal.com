<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>3422 W Idlewild — Renovation Command Center</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:        #0a0c0f;
    --surface:   #111418;
    --card:      #161b22;
    --border:    #21262d;
    --border2:   #30363d;
    --amber:     #f0a500;
    --amber2:    #ffc841;
    --green:     #3fb950;
    --red:       #f85149;
    --blue:      #58a6ff;
    --purple:    #bc8cff;
    --text:      #e6edf3;
    --muted:     #7d8590;
    --muted2:    #484f58;
    --mono:      'Space Mono', monospace;
    --sans:      'DM Sans', sans-serif;
    --display:   'Bebas Neue', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-size: 14px;
    line-height: 1.5;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── SCANLINE OVERLAY ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,.04) 2px, rgba(0,0,0,.04) 4px);
    pointer-events: none;
    z-index: 9999;
  }

  /* ── LAYOUT ── */
  .shell { max-width: 1440px; margin: 0 auto; padding: 0 24px 48px; }

  /* ── HEADER ── */
  header {
    position: sticky; top: 0; z-index: 100;
    background: rgba(10,12,15,.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 0 24px;
  }
  .header-inner {
    max-width: 1440px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
    height: 60px;
  }
  .header-left { display: flex; align-items: center; gap: 16px; }
  .site-badge {
    font-family: var(--display);
    font-size: 22px;
    letter-spacing: .05em;
    color: var(--amber);
  }
  .site-meta {
    display: flex; flex-direction: column;
    font-family: var(--mono);
    font-size: 10px;
    color: var(--muted);
    line-height: 1.3;
  }
  .site-meta span { color: var(--text); }
  .header-right { display: flex; align-items: center; gap: 12px; }
  .pulse-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 0 0 rgba(63,185,80,.5);
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%   { box-shadow: 0 0 0 0 rgba(63,185,80,.5); }
    70%  { box-shadow: 0 0 0 8px rgba(63,185,80,0); }
    100% { box-shadow: 0 0 0 0 rgba(63,185,80,0); }
  }
  .status-label {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--green);
    text-transform: uppercase;
    letter-spacing: .1em;
  }
  .last-updated {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--muted);
  }

  /* ── SECTION TITLE ── */
  .section-title {
    font-family: var(--display);
    font-size: 13px;
    letter-spacing: .15em;
    color: var(--amber);
    text-transform: uppercase;
    margin-bottom: 16px;
    display: flex; align-items: center; gap: 10px;
  }
  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--border2), transparent);
  }

  /* ── KPI STRIP ── */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 12px;
    margin: 28px 0;
  }
  .kpi-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 18px 16px 14px;
    position: relative;
    overflow: hidden;
    transition: border-color .2s;
  }
  .kpi-card:hover { border-color: var(--border2); }
  .kpi-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
  }
  .kpi-card.amber::before  { background: var(--amber); }
  .kpi-card.green::before  { background: var(--green); }
  .kpi-card.red::before    { background: var(--red); }
  .kpi-card.blue::before   { background: var(--blue); }
  .kpi-card.purple::before { background: var(--purple); }
  .kpi-card.muted::before  { background: var(--muted2); }

  .kpi-label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
  }
  .kpi-value {
    font-family: var(--mono);
    font-size: 22px;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 4px;
  }
  .kpi-card.amber  .kpi-value { color: var(--amber); }
  .kpi-card.green  .kpi-value { color: var(--green); }
  .kpi-card.red    .kpi-value { color: var(--red); }
  .kpi-card.blue   .kpi-value { color: var(--blue); }
  .kpi-card.purple .kpi-value { color: var(--purple); }
  .kpi-card.muted  .kpi-value { color: var(--text); }

  .kpi-sub {
    font-size: 11px;
    color: var(--muted);
    font-family: var(--mono);
  }

  /* ── PROGRESS BAR ── */
  .prog-wrap {
    background: var(--border);
    border-radius: 4px;
    height: 4px;
    margin-top: 10px;
    overflow: hidden;
  }
  .prog-bar {
    height: 100%;
    border-radius: 4px;
    transition: width 1s ease;
  }
  .prog-bar.amber  { background: var(--amber); }
  .prog-bar.green  { background: var(--green); }
  .prog-bar.red    { background: var(--red); }
  .prog-bar.blue   { background: var(--blue); }

  /* ── TWO-COL LAYOUT ── */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
  .three-col { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin-bottom: 20px; }
  .full-row { margin-bottom: 20px; }

  /* ── CARD ── */
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px;
  }
  .card-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }
  .card-title {
    font-family: var(--display);
    font-size: 17px;
    letter-spacing: .08em;
    color: var(--text);
  }
  .card-badge {
    font-family: var(--mono);
    font-size: 10px;
    padding: 3px 8px;
    border-radius: 4px;
    letter-spacing: .05em;
    text-transform: uppercase;
  }
  .badge-amber  { background: rgba(240,165,0,.15);   color: var(--amber);  border: 1px solid rgba(240,165,0,.3); }
  .badge-green  { background: rgba(63,185,80,.15);   color: var(--green);  border: 1px solid rgba(63,185,80,.3); }
  .badge-blue   { background: rgba(88,166,255,.15);  color: var(--blue);   border: 1px solid rgba(88,166,255,.3);}
  .badge-red    { background: rgba(248,81,73,.15);   color: var(--red);    border: 1px solid rgba(248,81,73,.3); }
  .badge-purple { background: rgba(188,140,255,.15); color: var(--purple); border: 1px solid rgba(188,140,255,.3);}
  .badge-muted  { background: rgba(125,133,144,.1);  color: var(--muted);  border: 1px solid var(--border2); }

  /* ── DRAW CARDS ── */
  .draw-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

  .draw-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color .2s, transform .2s;
  }
  .draw-card:hover { border-color: var(--border2); transform: translateY(-1px); }

  .draw-card-head {
    padding: 14px 16px 12px;
    border-bottom: 1px solid var(--border);
    display: flex; justify-content: space-between; align-items: flex-start;
  }
  .draw-num {
    font-family: var(--display);
    font-size: 11px;
    letter-spacing: .15em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 2px;
  }
  .draw-title {
    font-family: var(--sans);
    font-weight: 600;
    font-size: 13px;
    color: var(--text);
    line-height: 1.3;
  }
  .draw-budget {
    font-family: var(--mono);
    font-size: 15px;
    font-weight: 700;
    color: var(--amber);
    white-space: nowrap;
    margin-left: 12px;
  }

  .draw-dates {
    padding: 8px 16px;
    background: rgba(0,0,0,.2);
    display: flex; gap: 20px;
    border-bottom: 1px solid var(--border);
  }
  .draw-date-item { display: flex; flex-direction: column; }
  .draw-date-label { font-size: 9px; font-family: var(--mono); color: var(--muted); letter-spacing: .08em; text-transform: uppercase; }
  .draw-date-val   { font-size: 11px; font-family: var(--mono); color: var(--text); margin-top: 1px; }

  .draw-progress-section { padding: 12px 16px; border-bottom: 1px solid var(--border); }
  .draw-progress-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
  .draw-progress-label { font-size: 10px; font-family: var(--mono); color: var(--muted); }
  .draw-progress-pct   { font-size: 10px; font-family: var(--mono); color: var(--amber); }

  .draw-line-items { padding: 0; }
  .line-item {
    display: grid;
    grid-template-columns: 1fr 80px 90px 80px;
    align-items: center;
    padding: 8px 16px;
    border-bottom: 1px solid rgba(33,38,45,.6);
    gap: 8px;
    transition: background .15s;
  }
  .line-item:last-child { border-bottom: none; }
  .line-item:hover { background: rgba(255,255,255,.02); }
  .line-item-desc  { font-size: 11px; color: var(--text); line-height: 1.3; }
  .line-item-budget { font-family: var(--mono); font-size: 11px; color: var(--muted); text-align: right; }
  .line-item-spent {
    font-family: var(--mono);
    font-size: 11px;
    text-align: right;
    color: var(--text);
  }
  .line-item-spent input {
    width: 100%;
    background: rgba(255,255,255,.04);
    border: 1px solid var(--border2);
    border-radius: 4px;
    color: var(--green);
    font-family: var(--mono);
    font-size: 11px;
    padding: 3px 6px;
    text-align: right;
    outline: none;
    transition: border-color .15s;
  }
  .line-item-spent input:focus { border-color: var(--amber); }
  .line-item-status {
    display: flex;
    justify-content: flex-end;
  }
  .li-status-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--muted2);
  }
  .li-status-dot.done   { background: var(--green); }
  .li-status-dot.active { background: var(--amber); box-shadow: 0 0 6px var(--amber); }

  .draw-footer {
    padding: 10px 16px;
    background: rgba(0,0,0,.15);
    display: flex; justify-content: space-between; align-items: center;
  }
  .draw-totals { display: flex; gap: 20px; }
  .draw-total-item { display: flex; flex-direction: column; }
  .draw-total-label { font-size: 9px; font-family: var(--mono); color: var(--muted); letter-spacing: .08em; text-transform: uppercase; }
  .draw-total-val   { font-size: 13px; font-family: var(--mono); font-weight: 700; margin-top: 1px; }
  .draw-total-val.budget  { color: var(--amber); }
  .draw-total-val.spent   { color: var(--green); }
  .draw-total-val.remain  { color: var(--text); }

  /* status pill */
  .status-pill {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 20px;
    cursor: pointer;
    user-select: none;
    transition: all .2s;
  }
  .status-pill.not-started { background: rgba(125,133,144,.1); color: var(--muted); border: 1px solid var(--border2); }
  .status-pill.in-progress { background: rgba(240,165,0,.15);   color: var(--amber); border: 1px solid rgba(240,165,0,.3); }
  .status-pill.complete    { background: rgba(63,185,80,.15);   color: var(--green); border: 1px solid rgba(63,185,80,.3); }
  .status-pill.pending     { background: rgba(88,166,255,.15);  color: var(--blue);  border: 1px solid rgba(88,166,255,.3); }

  /* ── RISK TABLE ── */
  .risk-table { width: 100%; border-collapse: collapse; }
  .risk-table th {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0 12px 10px;
    text-align: left;
    border-bottom: 1px solid var(--border2);
  }
  .risk-table td {
    padding: 10px 12px;
    font-size: 12px;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }
  .risk-table tr:last-child td { border-bottom: none; }
  .risk-table tr:hover td { background: rgba(255,255,255,.02); }
  .risk-impact { font-family: var(--mono); font-size: 11px; color: var(--red); }
  .risk-draw   { font-family: var(--mono); font-size: 11px; color: var(--muted); }

  .risk-toggle {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
  }
  .risk-toggle input[type="checkbox"] {
    width: 16px; height: 16px;
    accent-color: var(--red);
    cursor: pointer;
  }

  /* ── TIMELINE ── */
  .timeline-grid { overflow-x: auto; }
  .gantt-table { width: 100%; border-collapse: collapse; min-width: 700px; }
  .gantt-table th {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .08em;
    color: var(--muted);
    padding: 0 8px 10px;
    text-align: center;
    border-bottom: 1px solid var(--border2);
  }
  .gantt-table th.left { text-align: left; }
  .gantt-table td {
    padding: 8px;
    border-bottom: 1px solid var(--border);
    font-size: 12px;
  }
  .gantt-table tr:last-child td { border-bottom: none; }
  .gantt-bar {
    height: 18px;
    border-radius: 3px;
    display: flex;
    align-items: center;
    padding: 0 6px;
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .05em;
    color: rgba(0,0,0,.7);
    font-weight: 700;
    white-space: nowrap;
    overflow: hidden;
    transition: opacity .2s;
  }
  .gantt-bar:hover { opacity: .85; }
  .gantt-cell { background: transparent; }
  .gantt-draw-label { font-size: 11px; color: var(--text); font-weight: 500; }
  .gantt-draw-budget { font-family: var(--mono); font-size: 11px; color: var(--amber); }
  .gantt-dates { font-family: var(--mono); font-size: 10px; color: var(--muted); }

  /* ── BOTTOM GRID ── */
  .bottom-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }

  /* ── BUDGET DONUT ── */
  .donut-wrap {
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .donut-svg { flex-shrink: 0; }
  .donut-legend { display: flex; flex-direction: column; gap: 10px; }
  .legend-row {
    display: flex; align-items: center; gap: 10px;
  }
  .legend-dot {
    width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0;
  }
  .legend-label { font-size: 12px; color: var(--muted); flex: 1; }
  .legend-val   { font-family: var(--mono); font-size: 12px; color: var(--text); }
  .legend-pct   { font-family: var(--mono); font-size: 11px; color: var(--muted); width: 36px; text-align: right; }

  /* ── NOTES / VENDOR ── */
  .notes-area {
    width: 100%;
    background: rgba(0,0,0,.2);
    border: 1px solid var(--border2);
    border-radius: 6px;
    color: var(--text);
    font-family: var(--mono);
    font-size: 12px;
    padding: 12px;
    resize: vertical;
    outline: none;
    line-height: 1.6;
    min-height: 120px;
    transition: border-color .15s;
  }
  .notes-area:focus { border-color: var(--amber); }

  .vendor-row {
    display: grid;
    grid-template-columns: 120px 1fr 100px 1fr;
    gap: 8px;
    margin-bottom: 8px;
    align-items: center;
  }
  .vendor-label { font-size: 11px; font-family: var(--mono); color: var(--muted); }
  .vendor-input {
    background: rgba(255,255,255,.04);
    border: 1px solid var(--border2);
    border-radius: 4px;
    color: var(--text);
    font-family: var(--mono);
    font-size: 11px;
    padding: 5px 8px;
    outline: none;
    width: 100%;
    transition: border-color .15s;
  }
  .vendor-input:focus { border-color: var(--amber); }

  /* ── FOOTER ── */
  footer {
    margin-top: 40px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  footer .f-left {
    font-family: var(--display);
    font-size: 13px;
    letter-spacing: .1em;
    color: var(--muted);
  }
  footer .f-right {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--muted2);
  }

  /* ── ANIMATIONS ── */
  .fade-in { animation: fadeIn .5s ease forwards; opacity: 0; }
  @keyframes fadeIn { to { opacity: 1; } }

  .slide-up { animation: slideUp .4s ease forwards; opacity: 0; transform: translateY(12px); }
  @keyframes slideUp { to { opacity: 1; transform: translateY(0); } }

  .kpi-card { animation: slideUp .4s ease forwards; opacity: 0; }
  .kpi-card:nth-child(1) { animation-delay: .05s; }
  .kpi-card:nth-child(2) { animation-delay: .1s; }
  .kpi-card:nth-child(3) { animation-delay: .15s; }
  .kpi-card:nth-child(4) { animation-delay: .2s; }
  .kpi-card:nth-child(5) { animation-delay: .25s; }
  .kpi-card:nth-child(6) { animation-delay: .3s; }

  /* ── UTILITY ── */
  .mono { font-family: var(--mono); }
  .text-muted { color: var(--muted); }
  .text-amber { color: var(--amber); }
  .text-green { color: var(--green); }
  .text-red   { color: var(--red); }
  .mt8  { margin-top: 8px; }
  .mt16 { margin-top: 16px; }

  /* ── RESPONSIVE ── */
  @media (max-width: 1100px) {
    .kpi-grid  { grid-template-columns: repeat(3, 1fr); }
    .draw-grid { grid-template-columns: 1fr; }
    .two-col   { grid-template-columns: 1fr; }
    .bottom-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<!-- HEADER -->
<header>
  <div class="header-inner">
    <div class="header-left">
      <div class="site-badge">SUAREZ CAPITAL</div>
      <div class="site-meta">
        <div>PROPERTY <span>3422 W Idlewild Ave, Tampa FL 33614</span></div>
        <div>ASSET TYPE <span>4-Unit Multifamily (Units A, B, C, D)</span></div>
      </div>
    </div>
    <div class="header-right">
      <div class="pulse-dot"></div>
      <div class="status-label">LIVE TRACKER</div>
      <div class="last-updated" id="lastUpdated">—</div>
    </div>
  </div>
</header>

<div class="shell">

  <!-- KPI STRIP -->
  <div class="kpi-grid" style="margin-top:28px;">
    <div class="kpi-card amber">
      <div class="kpi-label">Target Budget</div>
      <div class="kpi-value">$60K</div>
      <div class="kpi-sub">Range $60K–$70K</div>
      <div class="prog-wrap"><div class="prog-bar amber" id="prog-budget" style="width:0%"></div></div>
    </div>
    <div class="kpi-card muted">
      <div class="kpi-label">Project Total Est.</div>
      <div class="kpi-value">$67K</div>
      <div class="kpi-sub">4 draws · 4 units</div>
      <div class="prog-wrap"><div class="prog-bar amber" style="width:100%"></div></div>
    </div>
    <div class="kpi-card blue">
      <div class="kpi-label">Total Drawn</div>
      <div class="kpi-value" id="kpi-drawn">$0</div>
      <div class="kpi-sub" id="kpi-drawn-sub">0 of 4 draws</div>
      <div class="prog-wrap"><div class="prog-bar blue" id="prog-drawn" style="width:0%"></div></div>
    </div>
    <div class="kpi-card green">
      <div class="kpi-label">Total Spent</div>
      <div class="kpi-value" id="kpi-spent">$0</div>
      <div class="kpi-sub" id="kpi-spent-sub">0% of budget</div>
      <div class="prog-wrap"><div class="prog-bar green" id="prog-spent" style="width:0%"></div></div>
    </div>
    <div class="kpi-card red">
      <div class="kpi-label">Remaining</div>
      <div class="kpi-value" id="kpi-remaining">$60K</div>
      <div class="kpi-sub">Budget balance</div>
      <div class="prog-wrap"><div class="prog-bar red" id="prog-remaining" style="width:100%"></div></div>
    </div>
    <div class="kpi-card purple">
      <div class="kpi-label">Risk Exposure</div>
