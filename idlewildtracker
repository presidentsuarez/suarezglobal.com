// ── BUILD INSPECTION LOG ────────────────────────────────────────────────────
function buildInspections() {
  const tbody = document.getElementById('inspectionLog');
  const drawLabels = ['D1 – Roof','D2 – Units A/B','D3 – Units C/D','D4 – Site'];
  drawLabels.forEach((lbl, i) => {
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td style="font-size:11px;color:var(--muted);font-family:var(--mono);padding:6px 8px">${lbl}</td>
      <td style="padding:4px 8px"><input class="vendor-input" placeholder="Inspector name" style="width:100%"></td>
      <td style="padding:4px 8px"><input class="vendor-input" placeholder="MM/DD/YYYY" style="width:100%"></td>
      <td style="padding:4px 8px;text-align:center">
        <select style="background:var(--surface);border:1px solid var(--border2);border-radius:4px;color:var(--text);font-family:var(--mono);font-size:10px;padding:4px 6px;outline:none">
          <option value="">—</option>
          <option>Pass</option>
          <option>Fail</option>
          <option>Conditional</option>
