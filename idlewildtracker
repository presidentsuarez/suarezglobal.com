// ── BUILD DRAW LINE ITEMS ───────────────────────────────────────────────────
function buildDrawItems() {
  for (const [drawNum, draw] of Object.entries(draws)) {
    const container = document.getElementById(`items-${drawNum}`);
    draw.items.forEach((item, idx) => {
      const row = document.createElement('div');
      row.className = 'line-item';
