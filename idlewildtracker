}

// ── TOTALS ──────────────────────────────────────────────────────────────────
const TOTAL_BUDGET = 67000;

function updateTotals() {
  let grandSpent = 0;

  for (const [drawNum, draw] of Object.entries(draws)) {
    const inputs = document.querySelectorAll(`input[data-draw="${drawNum}"]`);
    let drawSpent = 0;
    inputs.forEach((inp, idx) => {
      const val = parseFloat(inp.value) || 0;
      drawSpent += val;
      const dot = document.getElementById(`dot-${drawNum}-${idx}`);
      if (dot) {
        dot.className = 'li-status-dot' + (val > 0 ? (val >= draw.items[idx].budget ? ' done' : ' active') : '');
      }
    });
    grandSpent += drawSpent;

    const pct = Math.min(100, Math.round((drawSpent / draw.budget) * 100));
    const progEl = document.getElementById(`d${drawNum}-prog`);
    const pctEl  = document.getElementById(`d${drawNum}-pct`);
    const spentEl  = document.getElementById(`d${drawNum}-spent-total`);
    const remainEl = document.getElementById(`d${drawNum}-remain`);

    if (progEl) progEl.style.width = pct + '%';
    if (pctEl)  pctEl.textContent = pct + '%';
    if (spentEl)  spentEl.textContent = fmt(drawSpent);
    if (remainEl) remainEl.textContent = fmt(Math.max(0, draw.budget - drawSpent));
  }

  // KPI strip
  const remaining = TOTAL_BUDGET - grandSpent;
  const pctSpent  = Math.min(100, Math.round((grandSpent / TOTAL_BUDGET) * 100));

  document.getElementById('kpi-drawn').textContent     = fmt(grandSpent);
  document.getElementById('kpi-spent').textContent     = fmt(grandSpent);
  document.getElementById('kpi-remaining').textContent = fmt(Math.max(0, remaining));
  document.getElementById('kpi-spent-sub').textContent = pctSpent + '% of budget';

  const drawsActive = [1,2,3,4].filter(d => {
    const inputs = document.querySelectorAll(`input[data-draw="${d}"]`);
    return [...inputs].some(i => parseFloat(i.value) > 0);
  }).length;
  document.getElementById('kpi-drawn-sub').textContent = drawsActive + ' of 4 draws active';

  document.getElementById('prog-drawn').style.width   = Math.min(100, Math.round((grandSpent / TOTAL_BUDGET)*100)) + '%';
  document.getElementById('prog-spent').style.width   = Math.min(100, pctSpent) + '%';
  document.getElementById('prog-remaining').style.width = Math.min(100, Math.round((remaining / TOTAL_BUDGET)*100)) + '%';

  updateTimestamp();
}

// ── RISK CALC ───────────────────────────────────────────────────────────────
const riskHighs = [5000, 4000, 3000, 1000, 2000];
function recalcRisk() {
  const checkboxes = document.querySelectorAll('.risk-toggle input[type="checkbox"]');
  let total = 0;
  checkboxes.forEach((cb, i) => { if (cb.checked) total += riskHighs[i]; });
  document.getElementById('risk-triggered').textContent = '+' + fmt(total);
  document.getElementById('risk-adjusted').textContent  = '~' + fmt(67000 + total);
}

// ── STATUS CYCLE ────────────────────────────────────────────────────────────
const statusCycle = ['not-started','in-progress','complete','pending'];
const statusLabel = {'not-started':'Not Started','in-progress':'In Progress','complete':'Complete','pending':'Pending Inspection'};
function cycleStatus(el) {
  const current = statusCycle.find(s => el.classList.contains(s)) || 'not-started';
  const next = statusCycle[(statusCycle.indexOf(current) + 1) % statusCycle.length];
  statusCycle.forEach(s => el.classList.remove(s));
  el.classList.add(next);
  el.textContent = statusLabel[next];
}

// ── FORMAT ──────────────────────────────────────────────────────────────────
function fmt(n) {
  if (n >= 1000) return '$' + (n/1000).toFixed(n % 1000 === 0 ? 0 : 1) + 'K';
  return '$' + n.toLocaleString();
}

function updateTimestamp() {
  const now = new Date();
  document.getElementById('lastUpdated').textContent =
    'Updated ' + now.toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});
}

// ── INIT ────────────────────────────────────────────────────────────────────
